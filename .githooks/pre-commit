#!/bin/sh
# Reminds (does not block) when a commit doesn't touch handoff.md or
# agentrunbook.md. See agentrunbook.md "Commit discipline" for the rule
# this enforces. Enable with: git config core.hooksPath .githooks

staged=$(git diff --cached --name-only)

echo "$staged" | grep -qx "handoff.md" && has_handoff=1
echo "$staged" | grep -qx "agentrunbook.md" && has_runbook=1

if [ -z "$has_handoff" ] || [ -z "$has_runbook" ]; then
  echo ""
  echo "reminder: this commit does not update handoff.md and/or agentrunbook.md"
  echo "  - handoff.md should reflect current session state after every commit"
  echo "  - agentrunbook.md should gain an entry for any new footgun/convention learned"
  echo "  (skip this for trivial commits — typos, formatting, etc.)"
  echo ""
fi

# lib/core/constants/build_info.dart (in-app version/commit label, see
# tool/gen_build_info.dart) records the git commit as of *last regeneration*
# — a pre-commit hook can't stamp its own commit's hash, so it will always
# lag one commit here. That's fine for its purpose (matching a device build
# back to roughly the right commit); just remind to regenerate before
# building for a real device test rather than trying to keep it exact here.
if ! echo "$staged" | grep -qx "lib/core/constants/build_info.dart"; then
  echo "reminder: run 'dart run tool/gen_build_info.dart' before building for a device test"
  echo "  so the in-app version label matches this commit."
  echo ""
fi

exit 0
