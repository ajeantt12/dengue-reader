#!/bin/sh
# Reminds (does not block) when a commit doesn't touch handoff.md or
# agentrunbook.md. See agentrunbook.md "Commit discipline" for the rule
# this enforces. Enable with: git config core.hooksPath .githooks

staged=$(git diff --cached --name-only)

echo "$staged" | grep -qx "handoff.md" && has_handoff=1
echo "$staged" | grep -qx "agentrunbook.md" && has_runbook=1

if [ -z "$has_handoff" ] || [ -z "$has_runbook" ]; then
  echo ""
  echo "reminder: this commit does not update handoff.md and/or agentrunbook.md"
  echo "  - handoff.md should reflect current session state after every commit"
  echo "  - agentrunbook.md should gain an entry for any new footgun/convention learned"
  echo "  (skip this for trivial commits — typos, formatting, etc.)"
  echo ""
fi

# The build label is passed at compile time, after the target commit exists.
# Keep it exact for a device test or release with:
# flutter build apk --release --dart-define=GIT_COMMIT=<short-hash>

exit 0
